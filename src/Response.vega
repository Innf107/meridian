import std:IO/Posix (writeString)
import std:Int
import meridian:Socket (Socket)
import meridian:Socket
import std:Array

data Response = Response({
    headers : Array({ key : String, value : String }),
    status : Int,
    statusMessage : String,
    contentType : String,
    body : String
})

sendResponse : (Socket, Response) -> ()
sendResponse(Socket(fd), Response({headers, status, statusMessage, contentType, body})) = {
    writeString(fd, "HTTP/1.1 ")
    writeString(fd, Int.toString(status))
    writeString(fd, " ")
    writeString(fd, statusMessage)
    writeString(fd, "\nContent-Type: ")
    writeString(fd, contentType)
    writeString(fd, "\n")
    
    Array.for(headers, \{key, value} -> {
        writeString(fd, key)
        writeString(fd, ", ")
        writeString(fd, value)
        writeString(fd, "\n")
    })
    writeString(fd, "\n")
    writeString(fd, body)
    Socket.close(fd)
}
